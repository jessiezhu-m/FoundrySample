FOUNDRY_ENDPOINT=https://your-ai-foundry.openai.azure.com/
FOUNDRY_DEPLOYMENT=gpt-4o
FOUNDRY_API_VERSION=2024-06-01

# Email is sent via Azure Communication Services (ACS) Email.
# ACS_CONNECTION_STRING comes from your ACS resource (Keys blade).
# EMAIL_FROM must be a sender address on a domain provisioned in ACS Email,
# for example DoNotReply@<guid>.azurecomm.net
ACS_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=your-access-key
EMAIL_FROM=DoNotReply@00000000-0000-0000-0000-000000000000.azurecomm.net
EMAIL_TO=recipient@example.com

SCHEDULE_TIMEZONE=Asia/Shanghai
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0
